<UserControl x:Class="Dmtd.Module.Views.DmtdView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             Background="{DynamicResource AppBackgroundBrush}"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Input:" Style="{StaticResource LabelTextBlock}"/>
                <ComboBox Width="280" Style="{StaticResource StyledComboBox}"
                          ItemsSource="{Binding InputDevices}"
                          SelectedItem="{Binding SelectedInputDevice}"
                          DisplayMemberPath="Name"/>
                <TextBlock Text="Rate:" Style="{StaticResource LabelTextBlock}" Margin="12,0,8,0"/>
                <ComboBox Width="90" Style="{StaticResource StyledComboBox}"
                          ItemsSource="{Binding SampleRates}"
                          SelectedItem="{Binding SelectedSampleRate}"/>
                <Button Command="{Binding StartStopCommand}" Width="88" Margin="12,0,0,0"
                        Content="{Binding StartStopButtonText}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentStopBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="Live Phase">
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,0" Padding="12,12,12,8">
                        <ScottPlot:WpfPlot x:Name="PhasePlot"/>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="20,24">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="Session" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <Button Content="Reset" Command="{Binding ResetPhaseCommand}"
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,0,6"/>
                                <Button Content="Download CSV" Command="{Binding DownloadHistoryCommand}"
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,0,6"
                                        Visibility="{Binding ShowDownloadCsv, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.ToolTip>
                                        <TextBlock Text="{Binding DownloadCsvToolTip}" TextWrapping="Wrap" MaxWidth="280"/>
                                    </Button.ToolTip>
                                </Button>
                                <Button Content="Set Zero" Command="{Binding SetZeroCommand}"
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,0,6"/>
                                <Button Content="Clear Zero" Command="{Binding ClearZeroCommand}"
                                        Style="{StaticResource SecondaryButton}" Margin="0,0,0,12"/>

                                <Grid Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Phase zero offset" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PhaseZeroDisplay}" FontFamily="Consolas" FontSize="13"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PhaseZeroActive}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <TextBlock Text="{Binding PrimaryMetricTitle}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <TextBlock Text="{Binding PrimaryMetricValue}" Style="{StaticResource MetricsHeroValue}"/>
                                    <TextBlock Text="{Binding PrimaryMetricUnit}" Style="{StaticResource MetricsHeroUnit}"/>
                                </StackPanel>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding SecondaryMetricTitle}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Window" Style="{StaticResource LabelTextBlock}" Margin="0,0,6,0"/>
                                        <TextBox Width="52" Style="{StaticResource StyledTextBox}"
                                                 Text="{Binding MaWindow, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <TextBlock Text="{Binding SecondaryMetricValue}" Style="{StaticResource MetricsSecondaryValue}"/>
                                    <TextBlock Text="{Binding SecondaryMetricUnit}" Style="{StaticResource MetricsSecondaryUnit}"/>
                                </StackPanel>

                                <TextBlock Text="{Binding DetailMetrics}" Style="{StaticResource MetricsDetail}"/>
                                <TextBlock Text="{Binding SlipWarningText}" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource WarningBrush}" Margin="0,16,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowSlipWarning}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Channels">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Content="Live" IsChecked="{Binding ChannelsLiveEnabled}" VerticalAlignment="Center"/>
                        <Button Content="Capture snapshot" Command="{Binding CaptureSnapshotCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="12,0,0,0"/>
                    </StackPanel>
                    <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                        <ScottPlot:WpfPlot x:Name="ChannelPlot"/>
                    </Border>
                    <Border Grid.Row="2" Style="{StaticResource CardBorder}">
                        <ScottPlot:WpfPlot x:Name="SnapshotPlot"/>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Configuration">
                <ScrollViewer Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel MaxWidth="900">
                            <TextBlock Text="Analyser Configuration" Style="{StaticResource SectionHeaderText}"/>
                            <UniformGrid Columns="2" Margin="0,0,0,8">
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Beat frequency (Hz)" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding BeatFrequency, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8">
                                    <TextBlock Text="Ref frequency (MHz)" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding RefFrequencyMhz, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Block size (samples)" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding BlockSize, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8">
                                    <TextBlock Text="Expansion factor (computed)" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding ExpansionFactorDisplay, Mode=OneWay}"
                                             IsReadOnly="True"
                                             Background="{DynamicResource SurfaceBrush}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Frequency estimator" Style="{StaticResource LabelTextBlock}"/>
                                    <ComboBox Style="{StaticResource StyledComboBox}"
                                              ItemsSource="{Binding FreqEstimatorOptions}"
                                              SelectedItem="{Binding SelectedFreqEstimator}"
                                              DisplayMemberPath="Label"/>
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8"
                                            Visibility="{Binding ShowFreqSource, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Frequency source" Style="{StaticResource LabelTextBlock}"/>
                                    <ComboBox Style="{StaticResource StyledComboBox}"
                                              ItemsSource="{Binding FreqSourceOptions}"
                                              SelectedItem="{Binding SelectedFreqSource}"
                                              DisplayMemberPath="Label"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Demodulation mode" Style="{StaticResource LabelTextBlock}"/>
                                    <ComboBox Style="{StaticResource StyledComboBox}"
                                              ItemsSource="{Binding DemodModeOptions}"
                                              SelectedItem="{Binding SelectedDemodMode}"
                                              DisplayMemberPath="Label"/>
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8">
                                    <TextBlock Text="IQ integration window" Style="{StaticResource LabelTextBlock}"/>
                                    <ComboBox Style="{StaticResource StyledComboBox}"
                                              ItemsSource="{Binding IqWindowOptions}"
                                              SelectedItem="{Binding SelectedIqWindow}"
                                              DisplayMemberPath="Label"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8"
                                            Visibility="{Binding ShowIqLpfFields, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="IQ LPF cutoff (Hz)" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding IqLpfCutoffHz, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8"
                                            Visibility="{Binding ShowIqLpfFields, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="IQ LPF order" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding IqLpfOrder, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8"
                                            Visibility="{Binding ShowIqMinMag, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="IQ min magnitude" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding IqMinMag, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8"
                                            Visibility="{Binding ShowPllFields, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="PLL Kp" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding PllKp, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8"
                                            Visibility="{Binding ShowPllFields, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="PLL Ki" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding PllKi, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8"
                                            Visibility="{Binding ShowPllFields, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="PLL min I/Q magnitude" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding PllMinMag, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="History retention (days)" Style="{StaticResource LabelTextBlock}"/>
                                    <TextBox Style="{StaticResource StyledTextBox}"
                                             Text="{Binding HistoryRetentionDays, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8" VerticalAlignment="Bottom">
                                    <CheckBox Content="Log phase history to disk"
                                              IsChecked="{Binding EnableHistoryLogging}"
                                              ToolTip="When enabled, each processed block is appended to history.db for CSV export."/>
                                </StackPanel>
                            </UniformGrid>
                            <Button Content="Save Configuration" Command="{Binding SaveConfigCommand}"
                                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,8,0,0" Padding="10,8">
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</UserControl>
