<UserControl x:Class="JitterMeasurement.Module.Views.JitterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             Background="{DynamicResource AppBackgroundBrush}"
             FontFamily="Segoe UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Capture" Style="{StaticResource SectionHeaderText}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Input device:" Style="{StaticResource LabelTextBlock}"/>
                    <ComboBox Width="320" Style="{StaticResource StyledComboBox}"
                              ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                              DisplayMemberPath="Name"/>
                    <TextBlock Text="Sample rate:" Style="{StaticResource LabelTextBlock}" Margin="16,0,8,0"/>
                    <ComboBox Width="100" Style="{StaticResource StyledComboBox}"
                              ItemsSource="{Binding SampleRates}" SelectedItem="{Binding SelectedSampleRate}"/>
                    <TextBlock Text="Input:" Style="{StaticResource LabelTextBlock}" Margin="16,0,8,0"/>
                    <ComboBox Width="60" Style="{StaticResource StyledComboBox}"
                              ItemsSource="{Binding InputChannels}" SelectedItem="{Binding SelectedInputChannel}"/>
                    <Button Command="{Binding StartStopCommand}" Width="88" Margin="16,0,0,0"
                            Content="{Binding StartStopButtonText}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentStopBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="12,0,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource CardBorder}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Measurement" Style="{StaticResource SectionHeaderText}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="f0 (MHz):" Style="{StaticResource LabelTextBlock}"/>
                    <TextBox Width="90" Style="{StaticResource StyledTextBox}"
                             Text="{Binding FundamentalMHz, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Harmonic N:" Style="{StaticResource LabelTextBlock}" Margin="16,0,8,0"/>
                    <TextBox Width="60" Style="{StaticResource StyledTextBox}"
                             Text="{Binding HarmonicNumber, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Integration (Hz):" Style="{StaticResource LabelTextBlock}" Margin="16,0,8,0"/>
                    <TextBox Width="60" Style="{StaticResource StyledTextBox}"
                             Text="{Binding IntegrationLowHz, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="–" Style="{StaticResource LabelTextBlock}" Margin="4,0"/>
                    <TextBox Width="70" Style="{StaticResource StyledTextBox}"
                             Text="{Binding IntegrationHighHz, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="FFT view (kHz):" Style="{StaticResource LabelTextBlock}" Margin="16,0,8,0"/>
                    <TextBox Width="50" Style="{StaticResource StyledTextBox}"
                             Text="{Binding FftViewMaxKHz, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Window (ms):" Style="{StaticResource LabelTextBlock}" Margin="16,0,8,0"/>
                    <TextBox Width="60" Style="{StaticResource StyledTextBox}"
                             Text="{Binding TimeWindowMs, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Calibrate" Command="{Binding CalibrateCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="16,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,8" Padding="12,12,12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="TimeAutoscaleButton" Grid.Row="0" Style="{StaticResource SecondaryButton}"
                            Content="Continuous auto: Off" Click="TimeAutoscaleButton_Click" HorizontalAlignment="Right"/>
                    <ScottPlot:WpfPlot x:Name="TimePlot" Grid.Row="1"/>
                </Grid>
            </Border>
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12,12,12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button x:Name="FftAutoscaleButton" Grid.Row="0" Style="{StaticResource SecondaryButton}"
                            Content="Continuous auto: Off" Click="FftAutoscaleButton_Click" HorizontalAlignment="Right"/>
                    <ScottPlot:WpfPlot x:Name="FftPlot" Grid.Row="1"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardBorder}" Padding="20,24">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding PrimaryMetricTitle}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="{Binding PrimaryMetricValue}" Style="{StaticResource MetricsHeroValue}"/>
                    <TextBlock Text="{Binding PrimaryMetricUnit}" Style="{StaticResource MetricsHeroUnit}"/>
                </StackPanel>
                <TextBlock Text="{Binding DetailMetrics}" Style="{StaticResource MetricsDetail}"/>
                <TextBlock Text="CLIP DETECTED" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource WarningBrush}" Margin="0,16,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowClipWarning}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
