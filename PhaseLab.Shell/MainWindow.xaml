<Window x:Class="PhaseLab.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhaseLab"
        Height="900"
        Width="1280"
        Icon="Assets/app.ico"
        MinHeight="700"
        MinWidth="1000"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="PhaseLab" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="VersionTextBlock" Style="{StaticResource LabelTextBlock}" Margin="8,2,0,0"/>
                    <TextBlock Text="Mode:" Style="{StaticResource LabelTextBlock}" Margin="20,0,8,0"/>
                    <ComboBox x:Name="ModeComboBox" Style="{StaticResource ModeToolbarComboBox}"
                              SelectionChanged="ModeComboBox_SelectionChanged"/>
                </StackPanel>
                <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Hyperlink Click="OpenApiDocs_Click">API Docs</Hyperlink>
                </TextBlock>
            </Grid>
        </Border>

        <ContentControl x:Name="ModuleContent" Grid.Row="1"/>
    </Grid>
</Window>
