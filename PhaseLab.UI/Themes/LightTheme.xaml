<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFECEFF4"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#FFD0D4DC"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FF1A1D24"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF5A6270"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF2563EB"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="AccentStopBrush" Color="#FFDC2626"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#FFC4C9D2"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC0392B"/>

    <sys:String x:Key="ChartFigureBackground">#FFFFFF</sys:String>
    <sys:String x:Key="ChartDataBackground">#FAFAFA</sys:String>
    <sys:String x:Key="ChartText">#333333</sys:String>
    <sys:String x:Key="ChartGrid">#888888</sys:String>
    <sys:String x:Key="ChartSignalColor">#1565C0</sys:String>
    <sys:String x:Key="ChartSecondaryColor">#7B1FA2</sys:String>
    <sys:String x:Key="ChartIntegrationLine">#1565C0</sys:String>

</ResourceDictionary>
